# ========================================
# MiGPT + Pi SDK 配置文件
# ========================================

# ===== 小米账号（必填，敏感信息请勿提交到版本控制）=====
MI_USER_ID=你的小米用户ID
MI_PASSWORD=你的小米密码
MI_DID=你的设备DID

# ===== OpenAI（默认提供商）=====
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxx
# 你的大模型服务接口，比如：https://api.openai.com/v1（注意：一般以 /v1 结尾）
# OPENAI_BASE_URL=https://api.openai.com/v1

# ===== Anthropic Claude（可选）=====
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxx

# ===== Google Gemini（可选）=====
# GOOGLE_API_KEY=xxxxxxxxxxxxxxx

# ===== DeepSeek（可选，推荐用于中文场景）=====
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxx
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ===== Azure OpenAI Service（可选）=====
# OPENAI_API_VERSION=2024-04-01-preview
# AZURE_OPENAI_API_KEY=你的密钥
# AZURE_OPENAI_ENDPOINT=https://你的资源名.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=你的模型部署名，比如：gpt-35-turbo-instruct

# ========================================
# Pi SDK 专属配置（可选）
# ========================================

# 默认 AI 提供商: openai | anthropic | google | deepseek
# PI_PROVIDER=openai

# 默认模型名称（会覆盖 OPENAI_MODEL）
# PI_MODEL=gpt-4o-mini

# 思考级别: off | low | medium | high
# PI_THINKING_LEVEL=off

# 最大对话历史轮数
# PI_MAX_HISTORY=10

# AI 回答最大长度（字数）
# PI_MAX_RESPONSE_LENGTH=200

# 是否启用流式响应（更快）
# PI_STREAMING=true

# 温度参数（0-2，越高越随机）
# PI_TEMPERATURE=0.7

# 自定义系统提示词（小爱音箱的 AI 人格）
# PI_SYSTEM_PROMPT=你是小爱音箱的智能助手...

# ========================================
# 提示音效（可选）
# ========================================

# AUDIO_SILENT=静音音频链接，示例：https://example.com/slient.wav
# AUDIO_BEEP=默认提示音链接，同上
# AUDIO_ACTIVE=唤醒提示音链接，同上
# AUDIO_ERROR=出错了提示音链接，同上

# ========================================
# 第三方 TTS（可选）
# ========================================

# TTS_BASE_URL=http://[你的局域网或公网地址]:[端口号]/[SECRET_PATH]/api
# 比如：http://192.168.31.205:4321/xxxx/api（注意：不要使用 localhost 或 127.0.0.1）

# ========================================
# 通义千问搜索功能（可选）
# ========================================

# qwen-vl系列、qwen开源系列与qwen-long模型暂时不支持配置该参数
# QWEN_ENABLE_SEARCH=true
